{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["ui/src/*"],
      "ui/*": ["ui/*"]
    },
    "esModuleInterop": true
  },
  "include": [
    "ui/src/**/*.d.ts",
    "ui/src/**/*.js",
    "ui/src/**/*.jsx",
    "ui/src/**/*.ts",
    "ui/src/**/*.tsx",
    "tests/**/*.js",
    "tests/**/*.jsx",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": ["node_modules", "ui/node_modules", "ui/dist"]
}
